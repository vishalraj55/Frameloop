generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  avatarUrl String?
  posts     Post[]
  likes     Like[]
  stories   Story[]
  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(uuid())
  imageUrl  String
  caption   String?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  likes     Like[]
  createdAt DateTime @default(now())
}

model Like {
  id     String @id @default(uuid())
  userId String
  postId String
  user   User   @relation(fields: [userId], references: [id])
  post   Post   @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Story {
  id        String   @id @default(uuid())
  imageUrl  String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}